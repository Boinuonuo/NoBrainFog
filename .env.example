# ==========================================
# 1.Core Selection
# ==========================================
# gemini or openai
AI_DRIVER=openai

# ==========================================
# 2. Discord Identity
# ==========================================
# Bot Token
DISCORD_TOKEN=your_discord_token_here

# Discord ID
TARGET_USER_ID=123456789012345678

# ==========================================
# 3. (Gemini Driver)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# 4. (OpenAI Driver)
# ==========================================
API_KEY=your_openai_or_grok_key_here
API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# ==========================================
# 5. (Preferences)
# ==========================================
MD_PATH=./todo.md
# without any space split catergories with,
CATEGORIES=Personal,Work,Shop,Art,Finance,Admin

# ==========================================
# 6. Adapter Selection
# ==========================================
# discord or wechat_work
ADAPTER_TYPE=discord

# ==========================================
# 7. WeChat Work Configuration
# ==========================================
# 企业微信企业 ID
WECHAT_CORP_ID=your_corp_id_here
# 企业微信应用 Secret
WECHAT_CORP_SECRET=your_corp_secret_here
# 企业微信应用 ID
WECHAT_AGENT_ID=1000001
# 企业微信应用 Token (用于验证)
WECHAT_TOKEN=your_token_here
# 企业微信应用 EncodingAESKey (消息加密)
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key_here
# 授权用户列表 (逗号分隔，留空表示允许所有用户)
AUTHORIZED_USERS=user1,user2,user3
