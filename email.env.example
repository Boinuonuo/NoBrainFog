# NoBrainFog Email IMAP adapter config
# Copy this file to /root/nobrainfog-config/email.env and edit it.

ADAPTER_TYPE=email_imap

# AI config. Required because emails are cleaned into structured todo rows.
AI_DRIVER=openai
API_KEY=your_openai_or_grok_key_here
API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Gemini alternative:
# AI_DRIVER=gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash

# Shared task vault.
MD_PATH=/root/nbf-vault/todo.md
CATEGORIES=Personal,Work,Shop,Art,Finance,Admin

# IMAP mailbox.
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=task@example.com
EMAIL_PASSWORD=your_email_app_password_here

# Optional.
EMAIL_MAILBOX=INBOX
EMAIL_POLL_SECONDS=60
EMAIL_MAX_MESSAGES_PER_POLL=10

# Optional. If set, successfully processed emails are copied here and deleted from INBOX.
# Leave empty to only mark successful emails as read.
EMAIL_PROCESSED_FOLDER=NoBrainFog/Processed

# Optional. Local dedupe marker directory.
# Leave empty to default to a hidden folder next to MD_PATH.
EMAIL_DEDUPE_DIR=/root/nbf-vault/.email_msg_dedupe

# Optional Discord DM notification for email capture success/failure.
# Reuse the same bot token and target user id as discord.env if you want notifications.
NOTIFY_DISCORD_ENABLED=false
DISCORD_TOKEN=your_discord_bot_token_here
TARGET_USER_ID=123456789012345678

# Optional SMTP reply config.
# Leave username/password empty to reuse EMAIL_USERNAME and EMAIL_PASSWORD.
EMAIL_SMTP_ENABLED=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_REPLY_FROM=

# Optional sender whitelist.
# If both are empty, all senders are allowed.
# Once either is configured, only matching senders/domains are processed.
# Commands such as /report, /export, and /excel also use this same whitelist.
EMAIL_ALLOWED_SENDERS=
EMAIL_ALLOWED_DOMAINS=
