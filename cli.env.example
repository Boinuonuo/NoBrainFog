# NoBrainFog CLI toolkit config
# Copy this file to /root/nobrainfog-config/cli.env and edit it.

# Required for all CLI commands.
MD_PATH=/root/nbf-vault/todo.md
CATEGORIES=Personal,Work,Shop,Art,Finance,Admin

# Required only for commands that use AI, such as:
#   python tools/nbf_cli.py --env-file /root/nobrainfog-config/cli.env add "task text"

AI_DRIVER=openai
API_KEY=your_openai_or_grok_key_here
API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Gemini alternative:
# AI_DRIVER=gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash
