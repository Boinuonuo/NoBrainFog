# ==========================================
# NoBrainFog WeChat Work Adapter Example
# Copy this file to your private config folder, for example:
#   /root/nobrainfog-config/wechat.env
# Do NOT commit your real .env files.
# ==========================================

# Adapter
ADAPTER_TYPE=wechat_work

# AI Driver: openai or gemini
AI_DRIVER=openai

# OpenAI-compatible driver
API_KEY=your_openai_or_grok_key_here
API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Gemini driver, only required when AI_DRIVER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# WeChat Work app credentials
WECHAT_CORP_ID=your_corp_id_here
WECHAT_CORP_SECRET=your_corp_secret_here
WECHAT_AGENT_ID=1000001

# WeChat Work callback verification
# These must match the Token and EncodingAESKey in the WeChat Work web console.
WECHAT_TOKEN=your_callback_token_here
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key_here

# Optional: comma-separated WeChat Work user IDs.
# Leave empty to allow all users who can access this app.
AUTHORIZED_USERS=

# Shared NoBrainFog data layer
# Point every adapter process to the same real todo.md file.
MD_PATH=/root/nbf-vault/todo.md

# Preferences
# No spaces after commas.
CATEGORIES=Personal,Work,Shop,Art,Finance,Admin
