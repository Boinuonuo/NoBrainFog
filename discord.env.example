# ==========================================
# NoBrainFog Discord Adapter Example
# Copy this file to your private config folder, for example:
#   /root/nobrainfog-config/discord.env
# Do NOT commit your real .env files.
# ==========================================

# Adapter
ADAPTER_TYPE=discord

# AI Driver: openai or gemini
AI_DRIVER=openai

# OpenAI-compatible driver
API_KEY=your_openai_or_grok_key_here
API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Gemini driver, only required when AI_DRIVER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Discord identity
DISCORD_TOKEN=your_discord_bot_token_here
TARGET_USER_ID=123456789012345678

# Shared NoBrainFog data layer
# Point every adapter process to the same real todo.md file.
MD_PATH=/root/nbf-vault/todo.md

# Preferences
# No spaces after commas.
CATEGORIES=Personal,Work,Shop,Art,Finance,Admin
